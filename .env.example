# Local SQLite path (default works out of the box)
DATABASE_URL=file:./appointly.db

# Mapbox — needed for map rendering and ZIP geocoding outside seed metros.
# Get a free token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Places — needed for pharmacy finder (Phase 3).
# Get a key at https://console.cloud.google.com/google/maps-apis
GOOGLE_PLACES_API_KEY=

# hCaptcha — production rate-limit on the accepting-patients verification flow.
# Get a free site key at https://www.hcaptcha.com/
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=
